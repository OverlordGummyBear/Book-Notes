<%- include("partials/header.ejs") %>

<div class="book-container">
    <% if(coverId !='unknown' ){ %>
        <img src="https://covers.openlibrary.org/b/id/<%= coverId %>-L.jpg" alt="picture of book cover">
    <% } else { %>
        <img src="/images/book-placeholder-L.jpg" alt="picture of placeholder cover" style="width: 40vh;">
    <% } %>

    <div class="book-details">
        <h2> <%= title %> </h2>
        <h3> By <%= author %> </h3>
        <h3> From <%= year %> </h3>

            <div id="review-changable" style="<%= locals.review != undefined ? 'display:none' : 'display: inline-block' %> ">
                <form id="review_form" style="display: none">
                    <input type="hidden" name="title" value="<%= title %>">
                    <input type="hidden" name="author" value="<%= author %>">
                    <input type="hidden" name="year" value="<%= year %>">
                    <input type="hidden" name="coverId" value="<%= coverId %>">
                    <input type="hidden" name="bookID" value="<%= locals.review != undefined ? review.book_id : undefined %>">
                
                    <input type="text" name="reviewTitle" placeholder="Title for your review" 
                        <%if(locals.review != undefined){ %> 
                            value="<%= review.review_title %>"    
                        <% } %> required>
                    <textarea id="review-text" name="reviewText" placeholder="Write review here..."
                        required><% if(locals.review != undefined){ %><%= review.review_text %><% } %></textarea>
                
                    <h3>Rating:</h3>
                    <div class="rating">
                        <input id="1" type="radio" name="rating" value="1">
                        <label for="1">
                            <span class="fa fa-star"></span>
                        </label>
                        <input id="2" type="radio" name="rating" value="2">
                        <label for="2">
                            <span class="fa fa-star"></span>
                        </label>
                        <input id="3" type="radio" name="rating" value="3">
                        <label for="3">
                            <span class="fa fa-star"></span>
                        </label>
                        <input id="4" type="radio" name="rating" value="4">
                        <label for="4">
                            <span class="fa fa-star"></span>
                        </label>
                        <input id="5" type="radio" name="rating" value="5">
                        <label for="5">
                            <span class="fa fa-star"></span>
                        </label>
                        <input id="0" type="checkbox" name="rating0" value="true" hidden>
                    </div>
                
                    <div>
                        <% if(locals.review == undefined){ %>
                            <input type="submit" value="Save" formaction="/addBook" formmethod="post">
                        <% } else { %>
                            <input type="submit" value="Update" formaction="/updateReview" formmethod="post">
                        <% } %>
                        <button type="button" onclick="confirmCancelation(<%= JSON.stringify(locals.review || null) %>)"> Cancel </button>
                    </div>
                </form>
                
                <button id="create_review" onclick="toogleVisibility()"> Create Review </button>
            </div>

            <% if(locals.review != undefined){ %>
                <div id="review-unchangeble" style="<%= locals.review != undefined ? 'display: inline-block' : 'display:none' %>">
                    <h2 class="review-title" style="font-size: 25px;"> <%= locals.review.review_title %> </h2>
                    <p style> <%= locals.review.review_text %> </p>
                    
                    <h4>Rating</h4>
                    <div class="starArray">
                        <% for(let i = 1; i <= review.rating; i++){ %>
                            <label class="checked stars<%= review.rating %>" style="pointer-events: none">
                                <span class="fa fa-star"></span>
                            </label>
                        <% } %>
                        <% for(let i = review.rating; i < 5; i++){ %>
                            <label style="pointer-events: none">
                                <span class="fa fa-star"></span>
                            </label>
                        <% } %>
                    </div>

                    <form id="unchangeble-form">
                        <button type="button" onclick="enableEdit(<%= JSON.stringify(locals.review.rating) %>)"> Edit </button>
                        <button onclick="deleteData('<%=review.book_id%>')" type="button">Delete</button>
                        
                    </form>
                </div>
            <% } %>

        
    </div>
</div>


<script>
    function enableEdit(starID){
        document.getElementById("review-changable").style.display = "inline-block";
        document.getElementById("review-unchangeble").style.display = "none";

        toogleVisibility();

        currentRating = 0; //reset to 0 so the correct amount of stars is checked when the label beneath is clicked on
        document.querySelector('label[for="' + starID + '"]').click();
        
        currentRating = starID;
    }

    function toogleVisibility() {
        var x = document.getElementById("review_form");
        document.getElementById("create_review").style.display = "none";

        if (x.style.display === "none") {
            x.style.display = "flex";
        } else {
            x.style.display = "none";
        }
    }

    function confirmCancelation(review){
        const confirmed = window.confirm("Are you sure you want to cancel the review?");

        if(confirmed){
            var form = document.getElementById('review_form');
            form.reset();
            form.style.display = "none";

            let temporaryCurrent = currentRating;

            if(review != null){
                currentRating = review.rating;

                document.getElementById("review-changable").style.display = "none";
                document.getElementById("review-unchangeble").style.display = "inline-block"; 
                
                let starArray = document.querySelectorAll(`.stars${currentRating}`);

                for (let i = 0; i < currentRating; i++) {
                    $(starArray[i]).addClass("checked");
                }  
            }

            if (review == null) { //Make create review button appear if canceling
                document.getElementById("create_review").style.display = "inline-block";

                document.querySelectorAll('.rating label').forEach(label => { //Reset the stars when canceling 
                    label.classList.remove('checked');
                    label.className = label.className.replace(/\bstars\d\b/g, '').trim();
                });
            }
        }

        if(review == null) currentRating = 0;
    }

    async function deleteData(bookId){
        const isConfirmed = window.confirm("Are you sure you want to delete this item?");

        if(!isConfirmed){
            console.log("Deletion is canceled by user");
            return;
        }

        try{
            const response = await fetch("/delete/" + bookId, { //send fetch request to delete endpoint
                method: "DELETE"
            });

            window.location.href = "/"; //redirect to home page
        } catch(error){
            console.error("There was a problem with the fetch operation: ", error);
        }
    }
</script>

<%- include("partials/footer.ejs") %>