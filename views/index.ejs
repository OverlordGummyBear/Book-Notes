<%- include("partials/header.ejs") %>

<div class="search-container">
    <form class="book-search" action="/search" method="post">
        <input class="search-bar" type="text" name="search" placeholder="Enter book name, author or isbn">
        <input type="submit" value="Search">
    </form>
</div>

<div class="content-container">
    <div class="sort">
        <p>Sort by </p>
        <form action="/sort" method="post">
            <select id="sort" name="sort"> <!--Make sure that the chosen sorting option is selected when loading the page -->
                <option value="book_title" <%=currentSort==='book_title' ? 'selected' : '' %>> Title </option>
                <option value="author" <%=currentSort==='author' ? 'selected' : '' %>>Author</option>
                <option value="rating_upward" <%=currentSort==='rating_upward' ? 'selected' : '' %>>Rating ASC</option>
                <option value="rating_downward" <%=currentSort==='rating_downward' ? 'selected' : '' %>>Rating DESC</option>
                <option value="newest" <%=currentSort==='newest' ? 'selected' : '' %>>Newest</option>
                <option value="oldest" <%=currentSort==='oldest' ? 'selected' : '' %>>Oldest</option>
            </select>
            <input type="submit" value="Go">
        </form>
    </div>

    

    <% if(locals.reviews != undefined && reviews.length > 0){ %>
        <% reviews.forEach(review =>{ %>
            <div class="review-container">
                <div class="book-info">
                    <form action="/book" method="post">
                        <input type="hidden" name="title" value="<%= review.title %>">
                        <input type="hidden" name="author" value="<%= review.author %>">
                        <input type="hidden" name="year" value="<%= review.year %>">
                        <input type="hidden" name="cover_i" value="<%= review.cover_id %>">

                        <% if(review.cover_id != null ){ %>
                            <input type="image" src="https://covers.openlibrary.org/b/id/<%= review.cover_id %>-M.jpg">
                        <% } else { %>
                            <input type="image" src="/images/book-placeholder-m.jpg">
                        <% } %>
                    </form>

                    <p> Book title: <%= review.title %> </p>
                    <p> Author: <%= review.author %></p>
                    
                    
                </div>
                <div class="review-details">
                    <h2 style="margin-top: 0px;"> <%= review.review_title %> </h2>
                    <p class="reviewText"> <%= review.review_text %> </p>

                    <!--Stars-->
                    <p> Rating </p>
                    <div class="starArray">
                        <% for(let i=1; i <=review.rating; i++){ %>
                            <label class="checked stars<%= review.rating %>" style="pointer-events: none">
                                <span class="fa fa-star"></span>
                            </label>
                        <% } %>
                            <% for(let i=review.rating; i < 5; i++){ %>
                                <label style="pointer-events: none">
                                    <span class="fa fa-star"></span>
                                </label>
                        <% } %>

                        <!--Date-->
                        <p> Date: <%= review.date %>
                        </p>
                    </div>

                    
                </div>
            </div>
        <% }) %>
    <% } else { %> 
        <div class="no-review-container">
            <h2>There are currently no reviews</h2>
        </div>
    <% } %>
</div>


<%- include("partials/footer.ejs") %>